{
    "buildCommand": "cd frontend-new && npm install && npm run build",
    "outputDirectory": "frontend-new/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/register",
            "destination": "/api/index.js"
        },
        {
            "source": "/jobs",
            "destination": "/api/index.js"
        },
        {
            "source": "/analyze-resume",
            "destination": "/api/index.js"
        }
    ]
}